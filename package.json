{
  "name": "test-starter-theme",
  "version": "2.0.0",
  "description": "A modern WordPress theme built for Gutenberg with full site editing support",
  "author": "Your Name",
  "license": "GPL-2.0-or-later",
"scripts": {
  "dev": "cross-env NODE_ENV=development postcss assets/css/tailwind.css -o assets/css/main.css --watch",
  "dev:watch": "cross-env NODE_ENV=development postcss assets/css/tailwind.css -o assets/css/main.css --watch",
  "build": "cross-env NODE_ENV=production postcss assets/css/tailwind.css -o assets/css/main.css",
  "build:webpack": "webpack --mode production",
  "dev:webpack": "webpack --mode development --watch",
  "lint": "eslint assets/js --fix",
  "lint:css": "stylelint assets/css --fix",
  "format": "prettier --write \"**/*.{js,json,css,scss,md,php}\"",
  "start": "npm run dev",
  "test": "jest"
},
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "@wordpress/babel-preset-default": "^7.0.0",
    "@wordpress/scripts": "^26.0.0",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "cross-env": "^10.1.0",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.1",
    "eslint": "^8.50.0",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.1.0",
    "prettier": "^3.0.0",
    "sass": "^1.68.0",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "browserslist": [
    "> 0.5%",
    "not dead",
    "not IE 11"
  ]
}
